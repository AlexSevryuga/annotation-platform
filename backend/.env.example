# LabelFlow Backend Environment Variables

# === Application ===
APP_NAME=LabelFlow API
VERSION=1.0.0
ENVIRONMENT=development

# === Database ===
DATABASE_URL=postgresql+asyncpg://annotation_user:annotation_pass@localhost:5432/annotation_db

# === Redis ===
REDIS_URL=redis://localhost:6379

# === S3 Storage ===
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=annotation-assets
S3_REGION=us-east-1

# === Auth (change in production!) ===
SECRET_KEY=change-me-in-production-use-strong-random-key
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production

# === CORS ===
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# === Celery ===
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# === ML Inference ===
SAM3_MODEL_PATH=
CUDA_DEVICE=cuda:0

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=60
